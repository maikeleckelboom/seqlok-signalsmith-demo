{
  "name": "seqlok-signalsmith-stretch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm run build:wasm && vite",
    "build": "pnpm run build:wasm && vue-tsc -b && vite build",
    "preview": "vite preview",
    "vendor": "tsx scripts/vendor.ts",
    "build:wasm": "tsx scripts/build.ts",
    "dev:shim": "cross-env DEV_SHIM=1 tsx scripts/build.ts && vite",
    "build:shim": "cross-env DEV_SHIM=1 tsx scripts/build.ts && vue-tsc -b && vite build",
    "build:all": "pnpm run vendor && pnpm run build"
  },
  "dependencies": {
    "@seqlok/commands": "workspace:*",
    "@seqlok/hotswap": "workspace:*",
    "@seqlok/integration": "workspace:*",
    "@tailwindcss/vite": "^4.1.17",
    "tailwindcss": "^4.1.17",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@types/audioworklet": "^0.0.92",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "execa": "^9.6.1",
    "prettier": "4.0.0-alpha.13",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.11",
    "vue-tsc": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
